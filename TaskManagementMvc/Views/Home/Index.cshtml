@using Microsoft.AspNetCore.Http

@{
    ViewData["Title"] = "Dashboard";
    var role = Context.Session.GetString("UserRole") ?? "Employee";
}

<div class="py-4">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="h3 mb-1">Task Management System</h1>
            <p class="text-muted mb-0">Manage tasks, categories, assignments, priorities, and deadlines.</p>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-md-6">
            <a asp-controller="Tasks" asp-action="Index" class="text-decoration-none">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <h2 class="h5 text-dark">Tasks</h2>
                        <p class="text-muted mb-0">View, create, update, assign, and delete task records.</p>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-6">
            <a asp-controller="Categories" asp-action="Index" class="text-decoration-none">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <h2 class="h5 text-dark">Categories</h2>
                        <p class="text-muted mb-0">Organize tasks into clear project or work categories.</p>
                    </div>
                </div>
            </a>
        </div>
        @if (role == "Admin")
        {
            <div class="col-md-6">
                <a asp-controller="Users" asp-action="Index" class="text-decoration-none">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <h2 class="h5 text-dark">User Management</h2>
                            <p class="text-muted mb-0">Admin area for reviewing users and changing employee roles.</p>
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>
</div>
