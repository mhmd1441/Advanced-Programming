@model TaskManagementMvc.ViewModels.TaskItemViewModel

@{
    ViewData["Title"] = "Task Details";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <h1 class="h3 mb-0">@Model.Title</h1>
    <div>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
        <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Description</dt>
            <dd class="col-sm-9">@Model.Description</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">@Model.Status</dd>

            <dt class="col-sm-3">Priority</dt>
            <dd class="col-sm-9">@Model.Priority</dd>

            <dt class="col-sm-3">Due Date</dt>
            <dd class="col-sm-9">@Model.DueDate.ToString("yyyy-MM-dd")</dd>

            <dt class="col-sm-3">Category</dt>
            <dd class="col-sm-9">@Model.Category?.Name</dd>

            <dt class="col-sm-3">Assigned To</dt>
            <dd class="col-sm-9">
                @if (Model.AssignedToUser == null)
                {
                    <span class="text-muted">Unassigned</span>
                }
                else
                {
                    <span>@Model.AssignedToUser.FirstName @Model.AssignedToUser.LastName (@Model.AssignedToUser.Email)</span>
                }
            </dd>
        </dl>
    </div>
</div>
