@model TaskManagementMvc.ViewModels.TaskFormViewModel

@{
    var role = ViewBag.UserRole as string ?? "Employee";
    var isAssignmentOnly = ViewBag.IsAssignmentOnly as bool? ?? false;
    var canAssign = role == "Admin" || role == "Manager";
}

<form method="post" class="card shadow-sm">
    <div class="card-body">
        <input asp-for="Id" type="hidden" />
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="row g-3">
            @if (isAssignmentOnly)
            {
                <input asp-for="Title" type="hidden" />
                <input asp-for="Description" type="hidden" />
                <input asp-for="Status" type="hidden" />
                <input asp-for="Priority" type="hidden" />
                <input asp-for="DueDate" type="hidden" />
                <input asp-for="CategoryId" type="hidden" />

                <div class="col-md-8">
                    <label class="form-label">Task</label>
                    <input value="@Model.Title" class="form-control" disabled />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Status</label>
                    <input value="@Model.Status" class="form-control" disabled />
                </div>
                <div class="col-md-6">
                    <label asp-for="AssignedToUserId" class="form-label">Assigned To</label>
                    <select asp-for="AssignedToUserId" asp-items="Model.Users" class="form-select"></select>
                    <span asp-validation-for="AssignedToUserId" class="text-danger"></span>
                </div>
            }
            else
            {
                <div class="col-md-8">
                    <label asp-for="Title" class="form-label"></label>
                    <input asp-for="Title" class="form-control" />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="DueDate" class="form-label"></label>
                    <input asp-for="DueDate" type="date" class="form-control" />
                    <span asp-validation-for="DueDate" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Status" class="form-label"></label>
                    <select asp-for="Status" class="form-select">
                        <option>To Do</option>
                        <option>In Progress</option>
                        <option>Blocked</option>
                        <option>Completed</option>
                    </select>
                    <span asp-validation-for="Status" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Priority" class="form-label"></label>
                    <select asp-for="Priority" class="form-select">
                        <option>Low</option>
                        <option>Medium</option>
                        <option>High</option>
                        <option>Urgent</option>
                    </select>
                    <span asp-validation-for="Priority" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="CategoryId" class="form-label">Category</label>
                    <select asp-for="CategoryId" asp-items="Model.Categories" class="form-select">
                        <option value="">Select category</option>
                    </select>
                    <span asp-validation-for="CategoryId" class="text-danger"></span>
                </div>
                @if (canAssign)
                {
                    <div class="col-md-6">
                        <label asp-for="AssignedToUserId" class="form-label">Assigned To</label>
                        <select asp-for="AssignedToUserId" asp-items="Model.Users" class="form-select"></select>
                        <span asp-validation-for="AssignedToUserId" class="text-danger"></span>
                    </div>
                }
                <div class="col-12">
                    <label asp-for="Description" class="form-label"></label>
                    <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>
            }
        </div>
    </div>
    <div class="card-footer bg-white text-end">
        <button type="submit" class="btn btn-primary">Save</button>
    </div>
</form>
