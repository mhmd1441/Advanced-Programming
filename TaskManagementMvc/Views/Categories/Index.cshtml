@model List<TaskManagementMvc.ViewModels.CategoryViewModel>

@{
    ViewData["Title"] = "Categories";
    var role = ViewBag.UserRole as string ?? "Employee";
    var canManage = role == "Admin";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <h1 class="h3 mb-0">Categories</h1>
    @if (canManage)
    {
        <a asp-action="Create" class="btn btn-primary">New Category</a>
    }
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}
@if (ViewBag.Error != null)
{
    <div class="alert alert-danger">@ViewBag.Error</div>
}

<div class="table-responsive">
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>Name</th>
                <th>Description</th>
                @if (canManage)
                {
                    <th class="text-end">Actions</th>
                }
            </tr>
        </thead>
        <tbody>
        @foreach (var category in Model)
        {
            <tr>
                <td>@category.Name</td>
                <td>@category.Description</td>
                @if (canManage)
                {
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@category.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                        <form asp-action="Delete" asp-route-id="@category.Id" method="post" class="d-inline">
                            <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                        </form>
                    </td>
                }
            </tr>
        }
        </tbody>
    </table>
</div>

@if (!Model.Any())
{
    <div class="text-muted">No categories found.</div>
}
